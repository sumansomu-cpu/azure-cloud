/dev/sdc /mnt/app1 ext4 defaults 0 0
/dev/sdd /app1 ext4 defaults 0 0
dev -> normal
sdc  -> disk name
/app1 -> where to mount
ext3 or ext4 


command to mount disk to particular mount-point
sudo mount /mnt/app1

command to mount all disks
sudo mount -a

command to umount all disks
sudo umount -a

command to umount particular mount-point
sudo umount /mnt/app1




